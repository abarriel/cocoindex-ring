# Postgres database for CocoIndex state + embeddings
COCOINDEX_DATABASE_URL=postgresql://cocoindex:cocoindex@localhost:5433/cocoindex

# LLM API key for entity extraction (pick one)
# Anthropic (Claude) -- https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Google Gemini -- https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Fallback to CPU for operations not supported by MPS on Mac.
# No-op on other platforms.
PYTORCH_ENABLE_MPS_FALLBACK=1
